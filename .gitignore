# 一、敏感信息 / 密钥配置
# 本地环境变量，包含 API Key、密钥等
# 永远不要提交到 Git 仓库
.env
.env.*
!.env.example

# 二、Python 运行缓存与虚拟环境
# Python 自动生成的缓存目录
__pycache__/

# Python 编译生成的字节码文件
*.pyc
*.pyo
*.pyd

# Python 打包和工具缓存目录
*.egg-info/
.pytest_cache/
.mypy_cache/

# 本地虚拟环境目录
.venv/
venv/

# 三、IDE / 编辑器配置文件
# PyCharm / IntelliJ IDEA 配置
.idea/

# VS Code 本地配置（与个人环境强相关）
.vscode/

# 四、本地实验 / 调试 / 过程文件
# AI Agent 协作过程文件（非最终成果）
AGENTS.md

# 本地测试 Notebook（反复运行、结果不稳定）
llmproj_test.ipynb

# 本地规划与分析文档（过程文件，不入库）
PLAN.md
project_analysis.md

# 本地复现实验脚本（个人环境相关，不入库）
reproduce.ps1

# 五、RAG 运行过程中生成的中间产物（CLI 模式）
# 文档切分结果，由程序自动生成，可重复生成
data/chunks.json

# 向量索引与 embedding 结果目录（CLI 默认输出）
# 每次构建可能不同，体积较大，不应入库
data/index/

# 六、Web 版 KB 运行数据（新增业务）
# 上传原文、索引文件、manifest 等运行期数据
data/kbs/

# 七、Web 前端构建产物（新增业务）
# 依赖目录与打包产物不入库
web/node_modules/
web/dist/

# 八、日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 九、系统文件
.DS_Store
Thumbs.db
